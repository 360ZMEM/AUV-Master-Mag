<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="drawio" version="26.0.0">
  <diagram name="statemachine-hierarchy">
    <mxGraphModel dx="1000" dy="700" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="2" value="多状态机层级与协同：策略层任务 FSM 唯一定阶段，控制层与感知层为子机制" style="text;html=1;align=center;verticalAlign=middle;fontSize=14;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="130" y="18" width="760" height="28" as="geometry" />
        </mxCell>

        <mxCell id="10" value="策略层（唯一权威状态机）" style="swimlane;horizontal=0;startSize=28;html=1;whiteSpace=wrap;rounded=0;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;fontColor=#274d20;" vertex="1" parent="1">
          <mxGeometry x="130" y="60" width="760" height="96" as="geometry" />
        </mxCell>
        <mxCell id="11" value="任务 FSM（mission_manager · 五态）&#xa;SEARCH → LOCK → TRACK → REACQUIRE_REGION（＋ EMERGENCY 终态）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=12;fontStyle=1;" vertex="1" parent="10">
          <mxGeometry x="175" y="16" width="450" height="46" as="geometry" />
        </mxCell>
        <mxCell id="12" value="决策：当前阶段 ＋ 速度因子 ＋ 制导源" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontStyle=2;fontColor=#4a7a2f;" vertex="1" parent="10">
          <mxGeometry x="175" y="66" width="450" height="20" as="geometry" />
        </mxCell>

        <mxCell id="20" value="控制层（受策略层调度的子机制）" style="swimlane;horizontal=0;startSize=28;html=1;whiteSpace=wrap;rounded=0;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;fontColor=#1f3a5f;" vertex="1" parent="1">
          <mxGeometry x="130" y="200" width="760" height="120" as="geometry" />
        </mxCell>
        <mxCell id="21" value="探测爆发子 FSM（probe_burst · 仅 TRACK 内使能）&#xa;IDLE → BURST → RECOVER → COOLDOWN" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="20">
          <mxGeometry x="60" y="20" width="330" height="52" as="geometry" />
        </mxCell>
        <mxCell id="22" value="控制器内子模式（无名）&#xa;翻腿 · 解耦横向 · 磁穿越探测 · 前视追踪" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="20">
          <mxGeometry x="410" y="20" width="330" height="52" as="geometry" />
        </mxCell>
        <mxCell id="23" value="输出：航向 / 速度指令（几何执行，不决定阶段）" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontStyle=2;fontColor=#3a5f8f;" vertex="1" parent="20">
          <mxGeometry x="60" y="84" width="680" height="20" as="geometry" />
        </mxCell>

        <mxCell id="30" value="感知层（提供输入，不直接发航向）" style="swimlane;horizontal=0;startSize=28;html=1;whiteSpace=wrap;rounded=0;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;fontStyle=1;fontColor=#6b5610;" vertex="1" parent="1">
          <mxGeometry x="130" y="364" width="760" height="120" as="geometry" />
        </mxCell>
        <mxCell id="31" value="局部路径状态（local_path）&#xa;COLLECTING · LINE · CURVE · REACQUIRE" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="30">
          <mxGeometry x="60" y="20" width="330" height="52" as="geometry" />
        </mxCell>
        <mxCell id="32" value="重捕区选择（ObservableRegionSelector）&#xa;有界候选 ＋ 打分" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="30">
          <mxGeometry x="410" y="20" width="330" height="52" as="geometry" />
        </mxCell>
        <mxCell id="33" value="输出：中心线几何 / 置信度 / 重捕区可用性 → PerceptionState" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontStyle=2;fontColor=#9c6a00;" vertex="1" parent="30">
          <mxGeometry x="60" y="84" width="680" height="20" as="geometry" />
        </mxCell>

        <mxCell id="100" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0;exitY=0.4;exitDx=0;exitDy=0;entryX=0;entryY=0.6;entryDx=0;entryDy=0;strokeColor=#d6b656;strokeWidth=1.6;" edge="1" parent="1" source="30" target="10">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="88" y="412" />
              <mxPoint x="88" y="118" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="101" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.6;exitDx=0;exitDy=0;entryX=1;entryY=0.4;entryDx=0;entryDy=0;strokeColor=#82b366;strokeWidth=1.6;" edge="1" parent="1" source="10" target="20">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="912" y="118" />
              <mxPoint x="912" y="248" />
            </Array>
          </mxGeometry>
        </mxCell>

        <mxCell id="102" value="TRACK 态使能" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.3;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#9673a6;strokeWidth=1.3;fontSize=10;fontColor=#6f4f86;dashed=1;" edge="1" parent="1" source="11" target="21">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="440" y="178" />
              <mxPoint x="355" y="178" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="103" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#9673a6;strokeWidth=1.3;dashed=1;" edge="1" parent="1" source="11" target="32">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="958" y="99" />
              <mxPoint x="958" y="410" />
            </Array>
          </mxGeometry>
        </mxCell>

        <mxCell id="110" value="① 感知输入&#xa;（上行）" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontStyle=1;fontColor=#9c6a00;" vertex="1" parent="1">
          <mxGeometry x="2" y="92" width="126" height="34" as="geometry" />
        </mxCell>
        <mxCell id="111" value="② 阶段调度&#xa;（下行）" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontStyle=1;fontColor=#4a7a2f;" vertex="1" parent="1">
          <mxGeometry x="848" y="160" width="120" height="34" as="geometry" />
        </mxCell>
        <mxCell id="112" value="REACQUIRE&#xa;态联动" style="text;html=1;align=center;verticalAlign=middle;fontSize=10;fontStyle=2;fontColor=#6f4f86;" vertex="1" parent="1">
          <mxGeometry x="892" y="424" width="100" height="34" as="geometry" />
        </mxCell>

        <mxCell id="200" value="图注：策略层任务 FSM 是唯一决定「当前处于哪个阶段」的权威状态机；控制层的探测爆发子 FSM 与控制器内子模式只在被授权阶段执行几何动作，感知层的局部路径状态与重捕区选择仅向上提供观测输入，二者均不直接决定任务阶段。① 上行：感知输入（几何＋置信度＋重捕区就绪）汇入策略层；② 下行：策略层按阶段调度控制层子机制。紫色虚线为典型纵向配合：TRACK 态使能探测爆发、REACQUIRE_REGION 态联动重捕区选择器。" style="text;html=1;align=left;verticalAlign=middle;fontSize=11;fontStyle=0;fontColor=#666666;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="130" y="500" width="820" height="64" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
