        <mxCell id="30" value="声呐定位观测&#xa;（sonar reading）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="830" y="195" width="150" height="50" as="geometry" />
        </mxCell>

        <mxCell id="31" value="块采样双速率：外层每帧约 20 Hz 推进，磁力计内层 200 Hz 逐样本跑滤波 / RMS；拟合与置信度每外层帧计算一次。&#xa;声呐定位点侧向汇入拟合器，消除中心线方向歧义（声磁协同入口）。" style="text;html=1;align=left;verticalAlign=middle;fontSize=12;fontStyle=0;fontColor=#666666;spacingLeft=8;" vertex="1" parent="1">
