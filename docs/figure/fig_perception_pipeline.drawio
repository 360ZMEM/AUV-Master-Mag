<mxfile host="drawio" version="26.0.0">
  <diagram name="perception-pipeline">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="2" value="磁感知融合流水线：原始磁场块 → 多级估计 → 统一感知状态（声磁协同）" style="text;html=1;align=center;verticalAlign=middle;fontSize=18;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="30" y="16" width="1020" height="30" as="geometry" />
        </mxCell>

        <mxCell id="32" value="内层 200 Hz 逐样本" style="text;html=1;align=center;verticalAlign=middle;fontSize=12;fontStyle=2;fontColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="30" y="58" width="150" height="18" as="geometry" />
        </mxCell>

        <mxCell id="10" value="原始磁场块&#xa;（block sampling）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="30" y="84" width="150" height="58" as="geometry" />
        </mxCell>
        <mxCell id="11" value="滤波 / RMS 包络&#xa;（filters）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="230" y="84" width="150" height="58" as="geometry" />
        </mxCell>
        <mxCell id="12" value="包络梯度+磁矢量&#xa;（vector）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="430" y="84" width="150" height="58" as="geometry" />
        </mxCell>
        <mxCell id="13" value="峰值检测&#xa;（peaks 升–峰–落）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="630" y="84" width="150" height="58" as="geometry" />
        </mxCell>
        <mxCell id="14" value="加权 PCA 中心线拟合&#xa;（fitter）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="830" y="84" width="150" height="58" as="geometry" />
        </mxCell>
        <mxCell id="15" value="局部路径几何&#xa;（local_path）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1030" y="84" width="150" height="58" as="geometry" />
        </mxCell>

        <mxCell id="16" value="无峰磁路径/前视/影子&#xa;（magnetic_path）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1030" y="300" width="150" height="58" as="geometry" />
        </mxCell>
        <mxCell id="17" value="横偏+埋深反演&#xa;（cross_track·burial）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="830" y="300" width="150" height="58" as="geometry" />
        </mxCell>
        <mxCell id="18" value="失锁重捕区&#xa;（reacquire_region）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="630" y="300" width="150" height="58" as="geometry" />
        </mxCell>
        <mxCell id="19" value="置信度融合&#xa;（confidence）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="430" y="300" width="150" height="58" as="geometry" />
        </mxCell>
        <mxCell id="20" value="统一感知状态&#xa;PerceptionState&#xa;（输出契约）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;fontStyle=1;fontColor=#1f3a5f;" vertex="1" parent="1">
